# ── Database ──────────────────────────────────────────────────────────────────
# SQLAlchemy connection string.
# Examples:
#   sqlite:///./app.db
#   postgresql://user:password@localhost:5432/dbname
DATABASE_URL=sqlite:///./app.db

# ── Application ───────────────────────────────────────────────────────────────
# development | production
APP_ENV=development

# ── LLM Service ───────────────────────────────────────────────────────────────
# stub  → no real LLM calls (default for local dev)
# openai → use OpenAI-compatible API
LLM_SERVICE=stub

# ── OpenAI ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=your-openai-api-key-here

# Model to use. Defaults to gpt-4o if unset.
DEFAULT_MODEL=gpt-4o

# Base URL for OpenAI-compatible endpoints (e.g. Azure, local Ollama, LM Studio).
# Leave blank to use the default OpenAI endpoint.
OPENAI_BASE_URL=
